pipeline {

 agent any

 stages {

 stage('Clone Repository') {
 steps {
 git 'https://github.com/harpreetsi94/mlops-project'
 }
 }

 stage('Install Dependencies') {
 steps {
 sh 'pip install -r requirements.txt'
 }
 }

 stage('Run Tests') {
 steps {
 sh 'pytest'
 }
 }

 stage('Build Docker Image') {
 steps {
 sh 'docker build -t harpreetsi94/house-price-ml:1.0 .'
 }
 }

 stage('Push Image') {
 steps {
 sh 'docker push harpreetsi94/house-price-ml:1.0'
 }
 }

 stage('Deploy to Kubernetes') {
 steps {
 sh 'kubectl apply -f kubernetes/'
 }
 }

 }

}
pipeline {
    agent any

    stages {

       stage('Clone Repo') {
    steps {
       git branch: 'main',  // ← change 'master' to 'main'
            url: 'https://github.com/harpreetsi94/mlops-house.git'
       
       }
               }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t ml-model:latest .'
            }
        }
        
       stage('Check Kubernetes Cluster') {
              steps {
        withEnv(['KUBECONFIG=C:\\ProgramData\\Jenkins\\.jenkins\\.kube\\config']) {
            bat 'kubectl cluster-info'
                  }
             }
         }

//checking if Kubernetes cluster is accessible from Jenkins server
        stage('Check Kubernetes Cluster') {
            steps {
                bat 'set KUBECONFIG=C:\\Users\\simra\\.kube\\config && kubectl cluster-info'
                bat 'set KUBECONFIG=C:\\Users\\simra\\.kube\\config && kubectl get nodes'
            }
        }
//for deployment, we need to have kubectl installed and configured in the Jenkins server to connect to the Kubernetes cluster
        stage('Deploy to Kubernetes') {
            steps {
                bat 'set KUBECONFIG=C:\\Users\\simra\\.kube\\config && kubectl apply -f kubernetes/'
            }
        }

    }
}
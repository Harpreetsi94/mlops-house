pipeline {

 agent any

 stages {

 stage('Clone Repo') {
 steps {
 git branch: 'main', url: 'https://github.com/harpreetsi94/mlops-house.git'
 }
 }

 stage('Build Docker') {
 steps {
 sh 'docker build -t ml-model .'
 }
 }

//for deployment, we need to have kubectl installed and configured in the Jenkins server to connect to the Kubernetes cluster

 stage('Deploy') {
 steps {
 sh 'kubectl apply -f kubernetes/'
 }
 }

 }

}
pipeline {
    agent any
    environment {
        KUBECONFIG = 'C:\\ProgramData\\Jenkins\\.kube\\config'
    }
    stages {
        stage('Clone Repo') {
            steps {
                git 'https://github.com/harpreetsi94/mlops-house.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t ml-model:latest .'
            }
        }

        stage('Set Kubernetes Context') {
            steps {
                bat 'kubectl config use-context minikube'
            }
        }

        stage('Load Image into Minikube') {
            steps {
                bat 'minikube image load ml-model:latest'
            }
        }

        stage('Check Kubernetes Cluster Info') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    bat 'kubectl cluster-info'
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                bat 'kubectl apply -f k8s/'
            }
        }
    }
}
```

---

## Summary
```
Before:  minikube restarts → random port (55963, 61234, etc.)
              └── Jenkins kubeconfig goes stale → pipeline fails

After:   minikube restarts → always port 8443
              └── Jenkins kubeconfig stays valid → pipeline works ✅

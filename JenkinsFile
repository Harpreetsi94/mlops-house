pipeline {

 agent any

 stages {

 stage('Clone Repo') {
 steps {
 git branch: 'main', url: 'https://github.com/harpreetsi94/mlops-house.git'
 }
 }

 stage('Build Docker') {
 steps {
 bat 'docker build -t ml-model .'
 }
 }

//for deployment, we need to have kubectl installed and configured in the Jenkins server to connect to the Kubernetes cluster

 stage('Deploy') {
 steps {
        bat 'kubectl config view'
        bat 'kubectl cluster-info'
        bat 'kubectl get nodes'
        bat 'set KUBECONFIG=C:\\Users\\simra\\.kube\\config && kubectl apply -f kubernetes/'
 }
 }

 }

}
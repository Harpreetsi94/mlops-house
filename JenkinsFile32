pipeline {

agent any

stages {

stage('Clone') {
steps {
git 'https://github.com/harpreetsi94/mlops-house.git'
}
}

stage('Build Docker') {
steps {
sh 'docker build -t harpreetsi94/ml-model:1.0 .'
}
}

stage('Push Image') {
steps {
sh 'docker push harpreetsi94/ml-model:1.0'
}
}

stage('Deploy Kubernetes') {
steps {
sh 'kubectl apply -f kubernetes/deployment.yaml'
sh 'kubectl apply -f kubernetes/service.yaml'
}
}

}

}